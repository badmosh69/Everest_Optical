# Copy this file to .env and fill in your real values for local development
# NEVER commit the real .env file to Git

DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
SECRET_KEY=change-this-to-a-long-random-string

# Flask-Mail (Gmail SMTP)
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an app password → copy the 16-character password below
MAIL_USERNAME=yourname@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx